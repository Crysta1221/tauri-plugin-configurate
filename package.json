{
  "name": "tauri-plugin-configurate-api",
  "version": "0.4.1",
  "description": "Tauri v2 plugin for type-safe application configuration management.",
  "keywords": [
    "config",
    "configuration",
    "keyring",
    "tauri",
    "tauri-plugin"
  ],
  "homepage": "https://github.com/Crysta1221/tauri-plugin-configurate",
  "bugs": {
    "url": "https://github.com/Crysta1221/tauri-plugin-configurate/issues"
  },
  "license": "MIT",
  "author": "Crysta1221",
  "repository": {
    "type": "git",
    "url": "https://github.com/Crysta1221/tauri-plugin-configurate.git"
  },
  "files": [
    "dist-js",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist-js/index.cjs",
  "module": "./dist-js/index.js",
  "types": "./dist-js/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-js/index.d.ts",
      "import": "./dist-js/index.js",
      "require": "./dist-js/index.cjs"
    },
    "./provider": {
      "types": "./dist-js/provider.d.ts",
      "import": "./dist-js/provider.js",
      "require": "./dist-js/provider.cjs"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "build:sync": "rollup -c && cd examples/tauri-app && pnpm install",
    "prepublishOnly": "bun run build",
    "pretest": "bun run build",
    "test": "bun test guest-js/*.test.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix"
  },
  "dependencies": {
    "oxlint-tsgolint": "^0.20.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/bun": "^1.3.10",
    "@types/web": "^0.0.344",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.20.0",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2.0.0"
  }
}
